# Copy to .env and fill in. Use with: docker compose --env-file .env run ...
# Or export variables before docker run.

# --- Host path (required for compose default; docker run uses -v instead) ---
HOST_WORKSPACE=.

# --- Paths inside the container ---
WORKSPACE_ROOT=/workspace
# Agents write here by default (created under the bind-mounted workspace).
AGENT_DATA_DIR=/workspace/.agent-data

# --- Startup policy (see README) ---
REQUIRE_WORKSPACE_MOUNT=1
REQUIRE_AGENT_DATA_MOUNT=0
# Optional: fail fast if keys missing — comma-separated: anthropic, gemini, cursor
# REQUIRE_API_KEYS=anthropic,gemini

# --- Auto-login (default: 1) ---
# When set, the entrypoint writes API keys into agent config directories
# (~/.claude, ~/.gemini, ~/.local/share/cursor-agent) so agents are
# "pre-logged-in" without passing env vars to every subprocess.
AUTO_LOGIN_AGENTS=1

# --- Optional: load keys from a file inside the container (mount it first) ---
# KEYS_ENV_FILE=/secrets/keys.env

# --- API keys (pass at runtime; do not commit real values) ---
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# CURSOR_API_KEY=

# --- Host CLI auth bundle (for "host-auth" compose profile) ---
# HOST_CLI_AUTH_BUNDLE=./host-cli-auth-bundle
