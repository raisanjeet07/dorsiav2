# Dorsia — Root Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Required API Keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ─── Optional API Keys ────────────────────────────────────────────────────────
CURSOR_API_KEY=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=research_workflows

# ─── Shared Config ────────────────────────────────────────────────────────────
# LOG_LEVEL applies to both capability-service and research-workflow
LOG_LEVEL=INFO
DEBUG=false

# Gateway: omit CLAUDE_CODE_DISABLE_RESUME for normal behavior (Claude session_id + --resume).
# CLAUDE_CODE_DISABLE_RESUME=1   # optional: one-shot, no multi-turn within a gateway session
# Optional: append JSON logs to a host file (also still printed to stdout). Compose sets this to logs/gateway/gateway.log.
# GATEWAY_LOG_FILE=logs/gateway/gateway.log

# Gateway: per-session agent dirs via workspace-file-service GET /api/v1/sessions/{sessionId}.
# Local dev: point at host port 8090. Disable integration: GATEWAY_WORKSPACE_FILE_SERVICE_URL=none
# Docker Compose sets http://workspace-file-service:8090 and mounts /data/workspaces on gateway + service.
GATEWAY_WORKSPACE_FILE_SERVICE_URL=http://localhost:8090

# workspace-file-service: absolute path to session root (repo: dorsia-workspace/)
WORKSPACE_FILE_ROOT=/Users/aarush/workspace/projects/ai_projects/dorsiav2/dorsia-workspace

# ─── Research Workflow Defaults ───────────────────────────────────────────────
RESEARCH_RESEARCHER_AGENT=gemini
RESEARCH_REVIEWER_AGENT=claude-code
# Max resolve/re-review loops before forced consensus (1 = one round, good for local testing)
# RESEARCH_DEFAULT_MAX_REVIEW_CYCLES=1
# RESEARCH_GATEWAY_CLAUDE_DISABLE_RESUME=true   # optional: one-shot Claude (default false)
