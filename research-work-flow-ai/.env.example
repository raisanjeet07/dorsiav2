# ── API Keys (used by the CLI Agent Gateway, not this service directly) ──
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# ── Research Service overrides (all optional — defaults shown) ──
# RESEARCH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_workflows
# RESEARCH_GATEWAY_WS_URL=ws://localhost:8080/ws
# RESEARCH_GATEWAY_HTTP_URL=http://localhost:8080
# RESEARCH_LOG_LEVEL=INFO
# RESEARCH_DEBUG=false
# RESEARCH_WORKSPACE_BASE_DIR=/workspace/research
# Max RE_REVIEWING→RESOLVING loops before forced consensus (1 = fast testing)
# RESEARCH_DEFAULT_MAX_REVIEW_CYCLES=1
# Run Gemini + Claude resolvers at the same time (two gateway processes). Default false = sequential.
# RESEARCH_RESOLVERS_PARALLEL=true
